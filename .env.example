# --- OSCAR Environment Variables ---
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Required for NewsAPI ingestor ---
# Free tier key: https://newsapi.org/register (instant approval)
NEWS_API_KEY=

# --- Optional API endpoints (defaults provided) ---
GDELT_BASE_URL=http://data.gdeltproject.org/gdeltv2/
GDELT_LAST_UPDATE_URL=http://data.gdeltproject.org/gdeltv2/lastupdate.txt
NEWS_API_BASE_URL=https://newsapi.org/v2/
REDDIT_BASE_URL=https://www.reddit.com/

# --- Optional: LLM enrichment ---
# OPENAI_API_KEY=
# HUGGINGFACE_HUB_TOKEN=

# --- Database ---
DATABASE_URL=sqlite:///data/oscar.db

# --- Application ---
APP_ENV=dev
LOG_LEVEL=INFO
STREAMLIT_THEME_BASE=light

# --- Refresh & limits ---
REFRESH_INTERVAL_MIN=15
GDELT_BATCH_HOURS_BACK=24
NEWSAPI_REQUESTS_PER_DAY=100
REDDIT_SUBREDDITS=worldnews,geopolitics,ukraine,IsraelPalestine,worldevents
REDDIT_MAX_POSTS_PER_SUB=50

# --- NLP models ---
SPACY_MODEL=en_core_web_sm
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- MLflow ---
MLFLOW_TRACKING_URI=mlruns/
MLFLOW_EXPERIMENT_NAME=oscar

# --- Observability ---
LOG_FORMAT=json
LOG_FILE=logs/oscar.log
